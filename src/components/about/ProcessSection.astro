---
import SectionHeading from "@/components/common/SectionHeading.astro";
import { aboutProcess } from "@/data/site";
---

<section class="section-space">
  <div class="app-container grid gap-6 xl:grid-cols-[0.9fr_1.1fr]">
    <div>
      <SectionHeading
        eyebrow="Proceso"
        title="Del concepto al acabado final."
        copy="Cada etapa combina criterio estetico y una revision constante de textura, brillo y proporcion."
      />
    </div>

    <div class="grid gap-4">
      {aboutProcess.map((item) => (
        <article class="glass-panel grid gap-4 p-5 sm:grid-cols-[auto_1fr] sm:items-start sm:gap-5 md:p-6" data-reveal>
          <span class="inline-flex h-12 w-12 items-center justify-center rounded-full bg-white/80 font-display text-xl text-brand-strong">
            {item.step}
          </span>
          <div>
            <h3 class="text-xl font-semibold">{item.title}</h3>
            <p class="body-copy mt-3">{item.description}</p>
          </div>
        </article>
      ))}
    </div>
  </div>
</section>
