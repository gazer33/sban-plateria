---
import SectionHeading from "@/components/common/SectionHeading.astro";
import { aboutHighlights } from "@/data/site";
---

<section class="section-space">
  <div class="app-container">
    <SectionHeading
      eyebrow="Lo que nos define"
      title="Lo que define cada pieza."
      copy="Principios que guian el diseno, la manufactura y la experiencia de marca en cada coleccion."
    />

    <div class="grid gap-5 lg:grid-cols-3">
      {aboutHighlights.map((item) => (
        <article class="glass-panel p-6 md:p-7" data-reveal>
          <span class="mb-4 inline-flex h-10 w-10 items-center justify-center rounded-full bg-white/75 text-sm font-bold text-brand-strong">
            SB
          </span>
          <h3 class="text-xl font-semibold">{item.title}</h3>
          <p class="body-copy mt-4">{item.description}</p>
        </article>
      ))}
    </div>
  </div>
</section>
