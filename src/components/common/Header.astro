---
import { navigationItems } from "@/data/site";

const currentPath = Astro.url.pathname;
---

<header class="sticky top-0 z-40 pt-3 md:pt-4" data-header>
  <div class="app-container relative">
    <div
      class="flex min-h-[4.25rem] items-center justify-between gap-4 rounded-[1.75rem] border border-line bg-[#faf8f4]/80 px-3.5 py-2.5 backdrop-blur-[18px] transition-shadow duration-200 md:min-h-20 md:rounded-full md:px-4"
      data-header-inner
    >
      <a class="inline-flex min-w-0 items-center gap-3" href="/" aria-label="SBAN Plateria, ir al inicio">
        <span class="grid h-10 w-10 flex-none place-items-center rounded-full bg-white/75 text-ink md:h-11 md:w-11">
          <svg class="h-full w-full p-1.5" viewBox="0 0 64 64">
            <circle cx="32" cy="32" r="30" fill="none" stroke="currentColor" stroke-width="1.4"></circle>
            <path d="M18 37c4-9 9-13 14-13 8 0 10 12 16 12 4 0 7-2 10-8" fill="none" stroke="currentColor" stroke-linecap="round" stroke-width="1.4"></path>
            <path d="M20 21h24" fill="none" stroke="currentColor" stroke-linecap="round" stroke-width="1.4"></path>
          </svg>
        </span>
        <span class="grid leading-none">
          <strong class="text-[0.95rem] tracking-[0.18em] md:text-base">SBAN</strong>
          <small class="mt-1 text-[0.7rem] uppercase tracking-[0.24em] text-muted md:text-[0.8rem]">Plateria</small>
        </span>
      </a>

      <nav class="hidden items-center gap-1 lg:flex" aria-label="Principal">
        {navigationItems.map((item) => (
          <a
            class:list={[
              "rounded-full px-4 py-3 text-[0.95rem] font-semibold text-muted transition-colors duration-200 hover:text-ink focus-visible:text-ink",
              currentPath === item.href && "text-ink"
            ]}
            href={item.href}
          >
            {item.label}
          </a>
        ))}
        <a class="action-button ml-2" href="/contacto">Agenda una asesoria</a>
      </nav>

      <button
        class="inline-grid h-12 w-12 flex-none place-items-center rounded-full border border-line bg-white/90 text-ink lg:hidden"
        type="button"
        aria-expanded="false"
        aria-controls="mobile-menu"
        aria-label="Abrir navegacion"
        data-menu-button
      >
        <svg class="h-5 w-5" aria-hidden="true" viewBox="0 0 24 24">
          <path d="M6 9.25h12" fill="none" stroke="currentColor" stroke-linecap="round" stroke-width="1.8"></path>
          <path d="M6 14.75h12" fill="none" stroke="currentColor" stroke-linecap="round" stroke-width="1.8"></path>
        </svg>
      </button>
    </div>

    <div class="fixed inset-0 z-30 hidden" data-mobile-shell hidden>
      <div class="absolute inset-0 bg-ink/18 backdrop-blur-md" data-mobile-backdrop></div>
      <nav
        id="mobile-menu"
        class="absolute left-1/2 top-[5.25rem] grid w-[calc(100vw-1rem)] max-w-sm -translate-x-1/2 gap-5 rounded-[1.75rem] border border-line bg-[#faf8f4]/95 p-4 shadow-[var(--shadow-panel)] backdrop-blur-[22px] sm:w-[calc(100vw-2rem)]"
        aria-label="Principal"
        data-mobile-menu
      >
        <div class="flex items-center justify-between gap-4">
          <span class="text-[0.8rem] font-bold uppercase tracking-[0.16em] text-muted">Menu</span>
          <button
            class="relative h-10 w-10 rounded-full border border-line bg-white/70"
            type="button"
            aria-label="Cerrar navegacion"
            data-menu-close
          >
            <span class="absolute left-1/2 top-1/2 h-px w-4 -translate-x-1/2 -translate-y-1/2 rotate-45 bg-ink"></span>
            <span class="absolute left-1/2 top-1/2 h-px w-4 -translate-x-1/2 -translate-y-1/2 -rotate-45 bg-ink"></span>
          </button>
        </div>

        <div class="grid gap-1.5">
          {navigationItems.map((item) => (
            <a
              class:list={[
                "flex min-h-14 items-center justify-between gap-4 rounded-3xl bg-white/70 px-4 py-4 text-ink transition duration-200 hover:-translate-y-0.5 hover:bg-white/95 focus-visible:-translate-y-0.5 focus-visible:bg-white/95",
                currentPath === item.href && "bg-brand-soft/35"
              ]}
              href={item.href}
              data-mobile-link
            >
              <span class="text-base font-semibold">{item.label}</span>
              <svg aria-hidden="true" class="h-4 w-4 flex-none" viewBox="0 0 24 24">
                <path d="M8 16 16 8M10 8h6v6" fill="none" stroke="currentColor" stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5"></path>
              </svg>
            </a>
          ))}
        </div>

        <a class="action-button action-button-primary min-h-14 w-full" href="/contacto" data-mobile-link>
          <span>Agenda una asesoria</span>
          <svg aria-hidden="true" class="h-4 w-4 flex-none" viewBox="0 0 24 24">
            <path d="M7 17L17 7M9 7h8v8" fill="none" stroke="currentColor" stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5"></path>
          </svg>
        </a>
      </nav>
    </div>
  </div>
</header>

<script>
  import { gsap } from "gsap";

  const header = document.querySelector("[data-header]");
  const headerInner = document.querySelector("[data-header-inner]");
  const menuButton = document.querySelector("[data-menu-button]");
  const closeButton = document.querySelector("[data-menu-close]");
  const mobileShell = document.querySelector("[data-mobile-shell]");
  const mobileMenu = document.querySelector("[data-mobile-menu]");
  const mobileBackdrop = document.querySelector("[data-mobile-backdrop]");
  const mobileLinks = document.querySelectorAll("[data-mobile-link]");
  const mobileQuery = window.matchMedia("(max-width: 1023px)");

  if (header instanceof HTMLElement && headerInner instanceof HTMLElement) {
    const syncHeaderState = () => {
      const scrolled = window.scrollY > 24;
      headerInner.classList.toggle("shadow-[0_18px_50px_rgba(24,32,42,0.08)]", scrolled);
      header.toggleAttribute("data-scrolled", scrolled);
    };

    syncHeaderState();
    window.addEventListener("scroll", syncHeaderState, { passive: true });
  }

  if (
    menuButton instanceof HTMLButtonElement &&
    closeButton instanceof HTMLButtonElement &&
    mobileShell instanceof HTMLDivElement &&
    mobileMenu instanceof HTMLElement &&
    mobileBackdrop instanceof HTMLDivElement
  ) {
    let isOpen = false;
    let menuTween: gsap.core.Tween | undefined;
    let backdropTween: gsap.core.Tween | undefined;

    const setClosedState = () => {
      mobileShell.hidden = true;
      mobileShell.classList.add("hidden");
      menuButton.setAttribute("aria-expanded", "false");
      document.body.style.overflow = "";
      isOpen = false;
    };

    const closeMenu = () => {
      if (!isOpen) {
        return;
      }

      menuTween?.kill();
      backdropTween?.kill();

      backdropTween = gsap.to(mobileBackdrop, {
        autoAlpha: 0,
        duration: 0.2,
        ease: "power2.out"
      });

      menuTween = gsap.to(mobileMenu, {
        autoAlpha: 0,
        y: -12,
        duration: 0.24,
        ease: "power2.in",
        onComplete: setClosedState
      });
    };

    const openMenu = () => {
      if (isOpen) {
        return;
      }

      mobileShell.hidden = false;
      mobileShell.classList.remove("hidden");
      isOpen = true;
      menuButton.setAttribute("aria-expanded", "true");
      document.body.style.overflow = "hidden";

      gsap.set(mobileBackdrop, { autoAlpha: 0 });
      gsap.set(mobileMenu, { autoAlpha: 0, y: -12 });

      backdropTween = gsap.to(mobileBackdrop, {
        autoAlpha: 1,
        duration: 0.22,
        ease: "power2.out"
      });

      menuTween = gsap.to(mobileMenu, {
        autoAlpha: 1,
        y: 0,
        duration: 0.28,
        ease: "power2.out"
      });
    };

    const syncMode = () => {
      if (!mobileQuery.matches) {
        closeMenu();
        gsap.set(mobileBackdrop, { clearProps: "all" });
        gsap.set(mobileMenu, { clearProps: "all" });
        mobileShell.hidden = true;
        mobileShell.classList.add("hidden");
      }
    };

    menuButton.addEventListener("click", () => {
      if (!mobileQuery.matches) {
        return;
      }

      if (isOpen) {
        closeMenu();
      } else {
        openMenu();
      }
    });

    closeButton.addEventListener("click", closeMenu);
    mobileBackdrop.addEventListener("click", closeMenu);
    mobileLinks.forEach((link) => link.addEventListener("click", closeMenu));

    window.addEventListener("keydown", (event) => {
      if (event.key === "Escape") {
        closeMenu();
      }
    });

    mobileQuery.addEventListener("change", syncMode);
    syncMode();
  }
</script>
