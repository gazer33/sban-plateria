---
import { navigationItems } from "@/data/site";

const currentPath = Astro.url.pathname;
---

<header class="site-header" data-header>
  <div class="container header-inner">
    <a class="brand" href="/" aria-label="SBAN Platería, ir al inicio">
      <span class="brand-mark" aria-hidden="true">
        <svg viewBox="0 0 64 64">
          <circle cx="32" cy="32" r="30" fill="none" stroke="currentColor" stroke-width="1.4"></circle>
          <path d="M18 37c4-9 9-13 14-13 8 0 10 12 16 12 4 0 7-2 10-8" fill="none" stroke="currentColor" stroke-linecap="round" stroke-width="1.4"></path>
          <path d="M20 21h24" fill="none" stroke="currentColor" stroke-linecap="round" stroke-width="1.4"></path>
        </svg>
      </span>
      <span class="brand-copy">
        <strong>SBAN</strong>
        <small>Platería</small>
      </span>
    </a>

    <details class="nav-toggle">
      <summary aria-label="Abrir navegación">
        <span></span>
        <span></span>
      </summary>
      <nav class="navigation" aria-label="Principal">
        {navigationItems.map((item) => (
          <a class:list={["nav-link", currentPath === item.href && "is-active"]} href={item.href}>
            {item.label}
          </a>
        ))}
        <a class="button-link nav-cta" href="/contacto">Agenda una asesoría</a>
      </nav>
    </details>
  </div>
</header>

<style>
  .site-header {
    position: sticky;
    top: 0;
    z-index: 20;
    padding: 1rem 0 0;
  }

  .site-header[data-scrolled] .header-inner {
    box-shadow: 0 18px 50px rgba(24, 32, 42, 0.08);
  }

  .header-inner {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 1rem;
    padding: 0.75rem 1rem;
    border: 1px solid rgba(24, 32, 42, 0.08);
    border-radius: 999px;
    background: rgba(250, 248, 244, 0.75);
    backdrop-filter: blur(18px);
  }

  .brand {
    display: inline-flex;
    align-items: center;
    gap: 0.9rem;
  }

  .brand-mark {
    width: 2.8rem;
    height: 2.8rem;
    display: grid;
    place-items: center;
    border-radius: 50%;
    background: rgba(255, 255, 255, 0.72);
    color: var(--color-text);
  }

  .brand-copy {
    display: grid;
    line-height: 1;
  }

  .brand-copy strong {
    font-size: 1rem;
    letter-spacing: 0.18em;
  }

  .brand-copy small {
    margin-top: 0.25rem;
    color: var(--color-muted);
    font-size: 0.8rem;
    letter-spacing: 0.24em;
    text-transform: uppercase;
  }

  .nav-toggle,
  .navigation {
    display: flex;
    align-items: center;
    gap: 0.4rem;
  }

  .nav-toggle summary {
    display: none;
    list-style: none;
  }

  .nav-toggle summary::-webkit-details-marker {
    display: none;
  }

  .nav-link {
    padding: 0.7rem 0.9rem;
    color: var(--color-muted);
    font-size: 0.95rem;
    font-weight: 600;
    transition: color 180ms ease;
  }

  .nav-link:hover,
  .nav-link:focus-visible,
  .nav-link.is-active {
    color: var(--color-text);
  }

  .nav-cta {
    margin-left: 0.5rem;
    padding-block: 0.8rem;
  }

  @media (max-width: 900px) {
    .site-header {
      padding-top: 0.75rem;
    }

    .header-inner {
      align-items: flex-start;
      padding: 0.75rem;
      border-radius: 30px;
    }

    .nav-toggle {
      flex-direction: column;
      align-items: flex-end;
      gap: 0.85rem;
    }

    .nav-toggle summary {
      display: grid;
      gap: 0.35rem;
      cursor: pointer;
      padding: 0.7rem;
      border: 1px solid var(--color-border);
      border-radius: 999px;
      background: rgba(255, 255, 255, 0.82);
    }

    .nav-toggle summary span {
      width: 1.25rem;
      height: 1px;
      background: var(--color-text);
    }

    .navigation {
      display: none;
      width: min(19rem, calc(100vw - 4rem));
      flex-direction: column;
      align-items: stretch;
      padding: 1rem;
      border: 1px solid var(--color-border);
      border-radius: 24px;
      background: rgba(255, 255, 255, 0.92);
      box-shadow: var(--shadow-soft);
    }

    .nav-toggle[open] .navigation {
      display: flex;
    }

    .nav-link,
    .nav-cta {
      margin: 0;
    }
  }
</style>
