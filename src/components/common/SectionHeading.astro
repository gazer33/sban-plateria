---
interface Props {
  eyebrow: string;
  title: string;
  copy: string;
  align?: "left" | "center";
}

const { eyebrow, title, copy, align = "left" } = Astro.props;
const centered = align === "center";
---

<div class:list={["mb-10 grid gap-4", centered && "justify-items-center text-center"]} data-reveal>
  <span class="eyebrow">
    <span class="eyebrow-line"></span>
    {eyebrow}
  </span>
  <h2 class="section-title">{title}</h2>
  <p class:list={["body-copy max-w-[62ch]", centered && "max-w-[54ch]"]}>{copy}</p>
</div>
