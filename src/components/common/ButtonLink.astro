---
interface Props {
  href: string;
  label: string;
  variant?: "primary" | "secondary";
}

const { href, label, variant = "secondary" } = Astro.props;
---

<a class:list={["button-link", variant === "primary" && "is-primary"]} href={href}>
  <span>{label}</span>
  <svg aria-hidden="true" viewBox="0 0 24 24">
    <path d="M7 17L17 7M9 7h8v8" fill="none" stroke="currentColor" stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5"></path>
  </svg>
</a>

<style>
  svg {
    width: 1rem;
    height: 1rem;
  }
</style>
