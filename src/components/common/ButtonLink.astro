---
interface Props {
  href: string;
  label: string;
  variant?: "primary" | "secondary";
  className?: string;
}

const { href, label, variant = "secondary", className = "" } = Astro.props;
---

<a
  class:list={[
    "action-button",
    variant === "primary" && "action-button-primary",
    className
  ]}
  href={href}
>
  <span>{label}</span>
  <svg aria-hidden="true" class="h-4 w-4 flex-none" viewBox="0 0 24 24">
    <path d="M7 17L17 7M9 7h8v8" fill="none" stroke="currentColor" stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5"></path>
  </svg>
</a>
