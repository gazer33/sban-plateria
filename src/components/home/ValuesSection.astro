---
import SectionHeading from "@/components/common/SectionHeading.astro";
import { values } from "@/data/site";
---

<section class="section">
  <div class="container values-shell card-surface">
    <SectionHeading
      eyebrow="Filosofía"
      title="Diseño contenido, oficio visible y materiales que hablan por sí mismos."
      copy="La marca se sostiene sobre principios claros que definen cada colección y cada interacción con el cliente."
    />

    <div class="values-grid">
      {values.map((value) => (
        <article class="value-item" data-reveal>
          <span class="value-icon" aria-hidden="true">
            <svg viewBox="0 0 24 24">
              <path d="M12 2l2.7 5.6L21 10l-4.5 4.3L17.5 21 12 18l-5.5 3 1-6.7L3 10l6.3-2.4L12 2Z" fill="none" stroke="currentColor" stroke-linejoin="round" stroke-width="1.2"></path>
            </svg>
          </span>
          <h3>{value.title}</h3>
          <p>{value.description}</p>
        </article>
      ))}
    </div>
  </div>
</section>

<style>
  .values-shell {
    padding: 2rem;
  }

  .values-grid {
    display: grid;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    gap: 1.2rem;
  }

  .value-item {
    padding: 1.5rem;
    border: 1px solid rgba(24, 32, 42, 0.08);
    border-radius: 24px;
    background: rgba(255, 255, 255, 0.72);
  }

  .value-icon {
    width: 2.75rem;
    height: 2.75rem;
    display: grid;
    place-items: center;
    margin-bottom: 1rem;
    border-radius: 50%;
    background: linear-gradient(180deg, rgba(234, 238, 242, 0.9), rgba(255, 255, 255, 0.95));
    color: var(--color-accent-strong);
  }

  h3,
  p {
    margin: 0;
  }

  h3 {
    margin-bottom: 0.7rem;
    font-size: 1.1rem;
  }

  p {
    color: var(--color-muted);
    line-height: 1.75;
  }

  @media (max-width: 900px) {
    .values-grid {
      grid-template-columns: 1fr;
    }
  }
</style>
