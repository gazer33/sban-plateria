---
import SectionHeading from "@/components/common/SectionHeading.astro";
import { values } from "@/data/site";
---

<section class="section-space">
  <div class="app-container">
    <div class="glass-panel p-6 md:p-8">
      <SectionHeading
        eyebrow="Filosofia"
        title="Diseno contenido, oficio visible y materiales que hablan por si mismos."
        copy="La marca se sostiene sobre principios claros que definen cada coleccion y cada interaccion con el cliente."
      />

      <div class="grid gap-5 lg:grid-cols-3">
        {values.map((value) => (
          <article class="rounded-[1.5rem] border border-line bg-white/75 p-6" data-reveal>
            <span class="mb-4 grid h-11 w-11 place-items-center rounded-full bg-linear-to-b from-[#eaEEF2]/90 to-white/95 text-brand-strong" aria-hidden="true">
              <svg class="h-5 w-5" viewBox="0 0 24 24">
                <path d="M12 2l2.7 5.6L21 10l-4.5 4.3L17.5 21 12 18l-5.5 3 1-6.7L3 10l6.3-2.4L12 2Z" fill="none" stroke="currentColor" stroke-linejoin="round" stroke-width="1.2"></path>
              </svg>
            </span>
            <h3 class="mb-3 text-[1.1rem] font-semibold">{value.title}</h3>
            <p class="body-copy">{value.description}</p>
          </article>
        ))}
      </div>
    </div>
  </div>
</section>
