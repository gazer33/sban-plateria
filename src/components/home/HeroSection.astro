---
import ButtonLink from "@/components/common/ButtonLink.astro";
---

<section class="section-space pt-9">
  <div class="app-container grid items-center gap-6 lg:grid-cols-[minmax(0,1.08fr)_minmax(20rem,0.92fr)]">
    <div class="grid gap-6 py-2 md:py-6" data-reveal>
      <span class="eyebrow">
        <span class="eyebrow-line"></span>
        Plateria contemporanea
      </span>
      <h1 class="display-title">Plata con presencia serena y detalle impecable.</h1>
      <p class="body-copy max-w-[62ch]">
        En SBAN Plateria diseniamos piezas de plata 925 que combinan pureza visual y sensibilidad
        contemporanea para acompaniar momentos que merecen permanecer.
      </p>
      <div class="flex flex-col gap-3 sm:flex-row sm:flex-wrap">
        <ButtonLink href="/productos" label="Explorar coleccion" variant="primary" />
        <ButtonLink href="/contacto" label="Atencion personalizada" />
      </div>
    </div>

    <div
      class="glass-panel parallax-layer relative isolate min-h-[22rem] overflow-hidden bg-[radial-gradient(circle_at_top,rgba(255,255,255,0.95),transparent_38%),linear-gradient(180deg,rgba(255,255,255,0.95),rgba(231,235,240,0.85))] p-6 sm:min-h-[29rem] md:p-8 lg:min-h-[42rem]"
      data-reveal
      data-parallax
    >
      <div class="absolute inset-[10%_8%] rounded-full border border-ink/7"></div>
      <div class="absolute inset-[22%_18%] rounded-full border border-ink/7"></div>

      <div class="absolute inset-[10%_10%_16%] grid place-items-center md:inset-[14%_16%_12%]">
        <svg viewBox="0 0 400 420" aria-hidden="true">
          <defs>
            <linearGradient id="silverGradient" x1="0%" y1="0%" x2="100%" y2="100%">
              <stop offset="0%" stop-color="#f6f7f8"></stop>
              <stop offset="40%" stop-color="#b9c0ca"></stop>
              <stop offset="70%" stop-color="#eef1f5"></stop>
              <stop offset="100%" stop-color="#8f98a4"></stop>
            </linearGradient>
          </defs>
          <path
            d="M200 40c60 0 110 38 110 104 0 34-15 59-35 86-15 20-25 39-25 64 0 41-24 86-50 86s-50-45-50-86c0-25-10-44-25-64-20-27-35-52-35-86 0-66 50-104 110-104Z"
            fill="url(#silverGradient)"
            stroke="rgba(255,255,255,.9)"
            stroke-width="6"
          ></path>
          <path
            d="M145 172c17-19 35-30 55-30 29 0 48 16 70 45"
            fill="none"
            stroke="rgba(255,255,255,.8)"
            stroke-linecap="round"
            stroke-width="7"
          ></path>
        </svg>
      </div>

      <div class="absolute bottom-6 right-6 grid max-w-48 gap-1 rounded-3xl border border-white/70 bg-white/75 px-4 py-4 backdrop-blur-md">
        <strong class="font-display text-[2rem] leading-none">925</strong>
        <span class="text-sm leading-6 text-muted">Plata fina de alta calidad</span>
      </div>
    </div>
  </div>
</section>
