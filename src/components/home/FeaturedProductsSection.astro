---
import SectionHeading from "@/components/common/SectionHeading.astro";
import { featuredProducts } from "@/data/site";
---

<section class="section">
  <div class="container">
    <SectionHeading
      eyebrow="Selección curada"
      title="Piezas destacadas que expresan presencia, textura y luz."
      copy="Una muestra inicial de la propuesta SBAN: plata hecha a mano con una lectura contemporánea y acabados de alto nivel."
    />

    <div class="featured-grid">
      {featuredProducts.map((item, index) => (
        <article class="featured-card card-surface" data-reveal style={`--delay: ${index * 0.08}s`}>
          <div class="featured-visual" aria-hidden="true">
            <svg viewBox="0 0 320 260">
              <defs>
                <linearGradient id={`metal-${index}`} x1="0%" y1="0%" x2="100%" y2="100%">
                  <stop offset="0%" stop-color="#ffffff"></stop>
                  <stop offset="50%" stop-color="#bcc4ce"></stop>
                  <stop offset="100%" stop-color="#f0f3f6"></stop>
                </linearGradient>
              </defs>
              <rect x="30" y="30" width="260" height="200" rx="42" fill={`url(#metal-${index})`} opacity="0.7"></rect>
              <circle cx="160" cy="130" r={index === 0 ? 54 : index === 1 ? 42 : 60} fill="none" stroke="rgba(255,255,255,.9)" stroke-width="8"></circle>
            </svg>
          </div>
          <span class="featured-tag">{item.tag}</span>
          <h3>{item.title}</h3>
          <p>{item.description}</p>
        </article>
      ))}
    </div>
  </div>
</section>

<style>
  .featured-grid {
    display: grid;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    gap: 1.25rem;
  }

  .featured-card {
    display: grid;
    gap: 1rem;
    padding: 1.35rem;
  }

  .featured-visual {
    padding: 0.65rem;
    border-radius: 24px;
    background: linear-gradient(180deg, rgba(255, 255, 255, 0.7), rgba(216, 222, 229, 0.75));
  }

  .featured-tag {
    display: inline-flex;
    width: fit-content;
    padding: 0.35rem 0.7rem;
    border-radius: 999px;
    background: rgba(255, 255, 255, 0.78);
    color: var(--color-muted);
    font-size: 0.76rem;
    font-weight: 700;
    letter-spacing: 0.08em;
    text-transform: uppercase;
  }

  h3,
  p {
    margin: 0;
  }

  h3 {
    font-size: 1.2rem;
  }

  p {
    color: var(--color-muted);
    line-height: 1.75;
  }

  @media (max-width: 900px) {
    .featured-grid {
      grid-template-columns: 1fr;
    }
  }
</style>
