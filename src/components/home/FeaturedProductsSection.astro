---
import SectionHeading from "@/components/common/SectionHeading.astro";
import { featuredProducts } from "@/data/site";
---

<section class="section-space">
  <div class="app-container">
    <SectionHeading
      eyebrow="Seleccion curada"
      title="Piezas destacadas que expresan presencia, textura y luz."
      copy="Una muestra inicial de la propuesta SBAN: plata hecha a mano con una lectura contemporanea y acabados de alto nivel."
    />

    <div class="grid gap-5 lg:grid-cols-3">
      {featuredProducts.map((item, index) => (
        <article class="glass-panel grid gap-4 p-5 md:p-6" data-reveal style={`--delay: ${index * 0.08}s`}>
          <div class="rounded-[1.5rem] bg-linear-to-b from-white/70 to-[#d8dee5]/75 p-3" aria-hidden="true">
            <svg viewBox="0 0 320 260">
              <defs>
                <linearGradient id={`metal-${index}`} x1="0%" y1="0%" x2="100%" y2="100%">
                  <stop offset="0%" stop-color="#ffffff"></stop>
                  <stop offset="50%" stop-color="#bcc4ce"></stop>
                  <stop offset="100%" stop-color="#f0f3f6"></stop>
                </linearGradient>
              </defs>
              <rect x="30" y="30" width="260" height="200" rx="42" fill={`url(#metal-${index})`} opacity="0.7"></rect>
              <circle cx="160" cy="130" r={index === 0 ? 54 : index === 1 ? 42 : 60} fill="none" stroke="rgba(255,255,255,.9)" stroke-width="8"></circle>
            </svg>
          </div>
          <span class="inline-flex w-fit rounded-full bg-white/80 px-3 py-1.5 text-[0.76rem] font-bold uppercase tracking-[0.08em] text-muted">
            {item.tag}
          </span>
          <h3 class="text-[1.2rem] font-semibold">{item.title}</h3>
          <p class="body-copy">{item.description}</p>
        </article>
      ))}
    </div>
  </div>
</section>
