---
import SectionHeading from "@/components/common/SectionHeading.astro";
import { urlForProductImage, type CatalogProduct } from "@/lib/sanity";

type ProductPreviewCard = {
  name: string;
  category: string;
  price: string;
  image?: CatalogProduct["image"];
  fallbackShape: number;
};

interface Props {
  products: ProductPreviewCard[];
}

const { products } = Astro.props;
---

<section class="section-space">
  <div class="app-container grid items-start gap-6 lg:grid-cols-[0.85fr_1.15fr]">
    <div>
      <SectionHeading
        eyebrow="Vista previa"
        title="Una seleccion de la coleccion actual."
        copy="Explora algunas de nuestras piezas mas recientes. Visita el catalogo para ver la coleccion completa con filtros y disponibilidad."
      />
    </div>

    <div class="grid gap-4 sm:grid-cols-2">
      {products.map((product, index) => (
        <article class="rounded-[1.625rem] border border-line bg-white/75 p-4 shadow-[var(--shadow-float)]" data-reveal>
          <div class="mb-4 overflow-hidden rounded-[1.375rem] bg-linear-to-b from-white/80 to-[#e6ebf1]/85" aria-hidden="true">
            {product.image ? (
              <img
                src={urlForProductImage(product.image).width(720).height(620).url()}
                alt={product.name}
                class="aspect-[16/13] w-full object-cover"
                loading="lazy"
                decoding="async"
              />
            ) : (
              <svg viewBox="0 0 260 220">
                <defs>
                  <linearGradient id={`piece-${index}`} x1="0%" y1="0%" x2="100%" y2="100%">
                    <stop offset="0%" stop-color="#ffffff"></stop>
                    <stop offset="100%" stop-color="#c3cbd4"></stop>
                  </linearGradient>
                </defs>
                <rect x="18" y="18" width="224" height="184" rx="34" fill={`url(#piece-${index})`}></rect>
                <path
                  d={product.fallbackShape % 2 === 0 ? "M78 110c0-28 23-50 52-50s52 22 52 50-23 50-52 50-52-22-52-50Z" : "M84 67h92v86H84z"}
                  fill="none"
                  stroke="rgba(255,255,255,.9)"
                  stroke-width="8"
                ></path>
              </svg>
            )}
          </div>
          <div>
            <span class="block text-sm text-muted">{product.category}</span>
            <strong class="mt-2 block text-[1.15rem] font-semibold">{product.name}</strong>
            <p class="mt-1 text-sm font-bold text-muted">{product.price}</p>
          </div>
        </article>
      ))}
    </div>
  </div>
</section>
