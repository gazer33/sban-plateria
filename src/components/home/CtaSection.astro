---
import ButtonLink from "@/components/common/ButtonLink.astro";
---

<section class="section-space">
  <div class="app-container">
    <div class="glass-panel flex flex-col gap-6 p-6 md:p-8 lg:flex-row lg:items-center lg:justify-between" data-reveal>
      <div class="grid gap-4">
        <span class="eyebrow">
          <span class="eyebrow-line"></span>
          Siguiente paso
        </span>
        <h2 class="section-title">Encuentra tu pieza.</h2>
        <p class="body-copy max-w-[62ch]">
          Conversemos sobre disponibilidad, personalizacion o seleccion de regalo. SBAN Plateria esta listo para
          acompaniarte con una experiencia cercana y cuidada.
        </p>
      </div>

      <div class="flex flex-col gap-3 sm:flex-row sm:flex-wrap lg:justify-end">
        <ButtonLink href="/contacto" label="Hablar con la marca" variant="primary" />
        <ButtonLink href="/nosotros" label="Conocer la historia" />
      </div>
    </div>
  </div>
</section>
