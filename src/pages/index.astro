---
import MainLayout from "@/layouts/MainLayout.astro";
import HeroSection from "@/components/home/HeroSection.astro";
import BrandIntroSection from "@/components/home/BrandIntroSection.astro";
import FeaturedProductsSection from "@/components/home/FeaturedProductsSection.astro";
import ValuesSection from "@/components/home/ValuesSection.astro";
import ProductShowcaseSection from "@/components/home/ProductShowcaseSection.astro";
import CtaSection from "@/components/home/CtaSection.astro";
import { fetchCatalogProducts, getFeaturedProducts, getPreviewProducts } from "@/lib/sanity";

const products = await fetchCatalogProducts();
const featuredProducts = getFeaturedProducts(products);
const previewProducts = getPreviewProducts(products);
---

<MainLayout
  title="SBAN Plateria | Joyeria de plata artesanal"
  description="SBAN Plateria crea piezas de plata artesanal con una estetica contemporanea, minimalista y premium."
>
  <HeroSection />
  <BrandIntroSection />
  <FeaturedProductsSection products={featuredProducts} />
  <ValuesSection />
  <ProductShowcaseSection products={previewProducts} />
  <CtaSection />
</MainLayout>
